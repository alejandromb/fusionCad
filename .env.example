# fusionCad Environment Variables
# Copy to .env and fill in values

# === API Server ===
PORT=3001
NODE_ENV=development

# === Database (Postgres) ===
# Option 1: Individual vars (local dev)
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fusion_cad

# Option 2: Connection string (Railway, Fly.io, Render)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# === CORS ===
# Comma-separated allowed origins (leave blank for permissive in dev)
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# === Auth (Cognito) ===
# Leave blank to disable auth (BYPASS_AUTH=true for dev)
BYPASS_AUTH=true
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# === AI Generation ===
ANTHROPIC_API_KEY=

# === Web Frontend (Vite — build-time only) ===
VITE_API_URL=http://localhost:3001
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=

# === OAuth (requires Cognito Hosted UI domain) ===
# VITE_COGNITO_OAUTH_DOMAIN=
# VITE_OAUTH_REDIRECT_SIGNIN=http://localhost:5173
# VITE_OAUTH_REDIRECT_SIGNOUT=http://localhost:5173
